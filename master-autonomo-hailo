import cv2
import numpy as np
import threading
import serial
import time
import uvicorn
from fastapi import FastAPI
from starlette.responses import StreamingResponse
from picamera2 import Picamera2
from hailo_platform import HEF, VDevice, InputVStreamParams, OutputVStreamParams, InferVStreams

# --- CONFIGURACIÓN TÉCNICA ---
MODELO_LANE = "lane.hef"
PUERTO_UART = "/dev/serial0"
BAUD_RATE = 115200
IMG_SIZE = 640          # Dimensión exacta de entrenamiento de la IA
FRECUENCIA_ENVIO = 3    # Procesar 3 imágenes antes de evaluar si mandamos comando
UMBRAL_ACTIVIDAD = 0.5  # Sensibilidad mínima de píxeles para detectar carril

class CarroCerebro:
    def __init__(self):
        self.frame_web = None
        self.lock = threading.Lock()
        self.stop_event = threading.Event()
        self.ultimo_comando = ""

cerebro = CarroCerebro()

# 1. CONEXIÓN UART (Comunicación Raspberry -> ESP32)
try:
    esp32 = serial.Serial(PUERTO_UART, BAUD_RATE, timeout=0.1)
    print(f"✅ UART conectado en {PUERTO_UART}")
except Exception as e:
    esp32 = None
    print(f"⚠️ Error UART: {e}. El carro NO se moverá físicamente.")

def loop_inteligencia():
    # 2. CONFIGURACIÓN DE CÁMARA (Captura de video)
    picam2 = Picamera2()
    # Capturamos a 640x480 (nativo) para luego reescalar a 640x640
    picam2.configure(picam2.create_preview_configuration({"size": (640, 480)}))
    picam2.start()

    # 3. INICIALIZACIÓN DEL CHIP HAILO (Acelerador de IA)
    target = VDevice()
    hef = HEF(MODELO_LANE)
    network_group = target.configure(hef)[0]
    input_name = hef.get_input_vstream_infos()[0].name

    contador_cuadros = 0

    with network_group.activate():
        # Configuramos los parámetros de entrada y salida del chip
        params = [InputVStreamParams.make(network_group), OutputVStreamParams.make(network_group)]
        
        with InferVStreams(network_group, *params) as pipe:
            print("🚀 CEREBRO ACTIVO: Analizando carril en 640x640...")

            while not cerebro.stop_event.is_set():
                # --- PASO A: CAPTURA Y TRANSFORMACIÓN (PRE-PROCESADO) ---
                frame_raw = picam2.capture_array()
                contador_cuadros += 1
                
                # Eliminamos canal Alpha y convertimos a RGB puro
                img_rgb = cv2.cvtColor(frame_raw, cv2.COLOR_RGBA2RGB) if frame_raw.shape[-1] == 4 else frame_raw
                
                # FORZAMOS 640x640: Esto es vital para que la segmentación sea exacta
                img_resized = cv2.resize(img_rgb, (IMG_SIZE, IMG_SIZE))
                
                # Preparamos los datos para el chip (expand_dims añade el "batch size")
                input_data = {input_name: np.expand_dims(img_resized, axis=0).astype(np.uint8)}

                # --- PASO B: INFERENCIA (EL CHIP TRABAJA) ---
                # El Hailo nos devuelve una "máscara" (píxeles 1 donde ve carril, 0 donde no)
                out = pipe.infer(input_data)
                mask = list(out.values())[0][0].astype(np.float32)

                # --- PASO C: SEGMENTACIÓN POR ZONAS (LÓGICA DE PESOS) ---
                # Dividimos el ancho (640px) en 5 rebanadas verticales de 128px cada una
                h, w = mask.shape[:2]
                seccion = w // 5
                
                # Factor de escala para que los números no sean tan grandes
                factor = 10000 
                z1 = np.sum(mask[:, :seccion]) / factor          # Extremo Izquierda
                z2 = np.sum(mask[:, seccion:seccion*2]) / factor    # Izquierda suave
                z3 = np.sum(mask[:, seccion*2:seccion*3]) / factor  # CENTRO (Ideal)
                z4 = np.sum(mask[:, seccion*3:seccion*4]) / factor  # Derecha suave
                z5 = np.sum(mask[:, seccion*4:]) / factor         # Extremo Derecha

                # --- PASO D: TOMA DE DECISIÓN Y CONTROL DE FLUJO ---
                # Solo evaluamos cada X cantidad de imágenes para evitar saturar la UART
                if contador_cuadros >= FRECUENCIA_ENVIO:
                    comando_decidido = "W" # Por defecto avanzar
                    
                    # 1. ¿El centro domina? -> Sigue Recto
                    if z3 > z2 and z3 > z4 and z3 > UMBRAL_ACTIVIDAD:
                        comando_decidido = "W"
                    # 2. ¿Hay más carril a la izquierda? -> Gira a la Izquierda
                    elif (z1 + z2) > (z4 + z5) and (z1 + z2) > UMBRAL_ACTIVIDAD:
                        comando_decidido = "A"
                    # 3. ¿Hay más carril a la derecha? -> Gira a la Derecha
                    elif (z4 + z5) > (z1 + z2) and (z4 + z5) > UMBRAL_ACTIVIDAD:
                        comando_decidido = "D"
                    # 4. ¿No vemos carril? -> Detener por seguridad
                    elif (z1+z2+z3+z4+z5) < UMBRAL_ACTIVIDAD:
                        comando_decidido = "X"

                    # FILTRO DE REDUNDANCIA: Solo mandar si el comando cambió respecto al anterior
                    if comando_decidido != cerebro.ultimo_comando:
                        if esp32:
                            esp32.write(f"{comando_decidido}\n".encode())
                            esp32.flush() # Limpia el canal físico
                        cerebro.ultimo_comando = comando_decidido
                    
                    contador_cuadros = 0 # Reiniciar contador de frames

                # --- PASO E: FEEDBACK VISUAL (PARA TI) ---
                frame_viz = cv2.cvtColor(frame_raw, cv2.COLOR_RGB2BGR)
                # Dibujamos las líneas de las 5 zonas en el video
                for i in range(1, 5):
                    cv2.line(frame_viz, (i * (640//5), 0), (i * (640//5), 480), (255, 255, 0), 1)
                
                # Escribimos el comando actual y el estado de las zonas
                cv2.putText(frame_viz, f"ORDEN: {cerebro.ultimo_comando}", (20, 60), 1, 3, (0, 255, 0), 4)
                cv2.putText(frame_viz, f"Z3: {z3:.1f}", (240, 450), 1, 1.5, (255, 255, 255), 2)

                # Comprimir imagen para transmitir por WiFi a la laptop
                _, buffer = cv2.imencode('.jpg', frame_viz, [cv2.IMWRITE_JPEG_QUALITY, 50])
                with cerebro.lock:
                    cerebro.frame_web = buffer.tobytes()

    picam2.stop()

# --- SERVIDOR WEB (FASTAPI) PARA MONITOREO REMOTO ---
app = FastAPI()

@app.get("/")
def video_feed():
    def generate():
        while True:
            with cerebro.lock:
                if cerebro.frame_web:
                    yield (b'--frame\r\nContent-Type: image/jpeg\r\n\r\n' + cerebro.frame_web + b'\r\n')
            time.sleep(0.04) # Control de frames del stream (~25 fps)
    return StreamingResponse(generate(), media_type="multipart/x-mixed-replace; boundary=frame")

if __name__ == "__main__":
    # Iniciamos la lógica de la IA en un hilo separado del servidor web
    t = threading.Thread(target=loop_inteligencia, daemon=True)
    t.start()
    
    # Arrancamos el monitor web en el puerto 5000
    print("🌐 Monitor web activo en: http://[IP_DE_TU_RASPBERRY]:5000")
    uvicorn.run(app, host="0.0.0.0", port=5000, log_level="error")