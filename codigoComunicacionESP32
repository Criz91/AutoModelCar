import socket
import threading
import time
import queue
import tkinter as tk
from tkinter import scrolledtext
from pynput import keyboard

HOST = "192.168.4.1"   # IP del AP de la ESP32
PORT = 8080

SEND_INTERVAL = 0.08   # 80 ms
BASE_SPEED = 120
TURN_VALUE = 80

sock = None
running = True

pressed_keys = set()
current_mode = "MANUAL"

log_queue = queue.Queue()
sock_lock = threading.Lock()

root = None
status_label = None
log_text = None
entry_text = None
mode_label = None


def push_log(msg: str):
    log_queue.put(msg)


def send_line(line: str):
    global sock
    try:
        with sock_lock:
            if sock is not None:
                sock.sendall((line + "\n").encode("utf-8"))
                push_log(f"[TX] {line}")
    except Exception as e:
        push_log(f"[ERROR] No se pudo enviar: {e}")


def receiver_loop():
    global running, sock
    while running:
        try:
            with sock_lock:
                if sock is None:
                    break
                data = sock.recv(1024)

            if not data:
                push_log("[INFO] Conexion cerrada por la ESP32")
                running = False
                break

            text = data.decode("utf-8", errors="ignore")
            for line in text.splitlines():
                push_log(f"[RX] {line}")

        except Exception as e:
            if running:
                push_log(f"[ERROR] Recepcion: {e}")
            running = False
            break


def compute_command():
    speed = 0
    turn = 0

    w = "w" in pressed_keys
    s = "s" in pressed_keys
    a = "a" in pressed_keys
    d = "d" in pressed_keys

    if w and not s:
        speed = BASE_SPEED
    elif s and not w:
        speed = -BASE_SPEED

    if a and not d:
        turn = -TURN_VALUE
    elif d and not a:
        turn = TURN_VALUE

    return speed, turn


def sender_loop():
    global running, current_mode

    last_sent = None

    while running:
        speed, turn = compute_command()
        cmd = f"CMD,{current_mode},{speed},{turn}"

        if cmd != last_sent or speed != 0 or turn != 0:
            send_line(cmd)
            last_sent = cmd

        time.sleep(SEND_INTERVAL)


def set_mode_manual():
    global current_mode
    current_mode = "MANUAL"
    send_line("MODE,MANUAL")
    update_mode_label()
    push_log("[INFO] Modo MANUAL")


def set_mode_auto():
    global current_mode
    current_mode = "AUTO"
    send_line("MODE,AUTO")
    update_mode_label()
    push_log("[INFO] Modo AUTO")


def send_stop():
    pressed_keys.clear()
    send_line("STOP")
    push_log("[INFO] STOP")


def send_custom_text():
    text = entry_text.get().strip()
    if not text:
        return
    send_line(text)
    entry_text.delete(0, tk.END)


def update_mode_label():
    if mode_label is not None:
        mode_label.config(text=f"Modo actual: {current_mode}")


def on_press(key):
    global running, current_mode

    try:
        k = key.char.lower()

        if k in ["w", "a", "s", "d"]:
            pressed_keys.add(k)

        elif k == "m":
            set_mode_manual()

        elif k == "o":
            set_mode_auto()

        elif k == "q":
            push_log("[INFO] Saliendo...")
            close_program()
            return False

    except AttributeError:
        if key == keyboard.Key.space:
            send_stop()


def on_release(key):
    try:
        k = key.char.lower()
        if k in pressed_keys:
            pressed_keys.remove(k)
    except AttributeError:
        pass


def process_log_queue():
    while not log_queue.empty():
        msg = log_queue.get()
        if log_text is not None:
            log_text.insert(tk.END, msg + "\n")
            log_text.see(tk.END)
    if running and root is not None:
        root.after(100, process_log_queue)


def close_program():
    global running, sock

    if not running:
        return

    running = False

    try:
        send_line("STOP")
    except:
        pass

    time.sleep(0.1)

    try:
        with sock_lock:
            if sock is not None:
                sock.close()
                sock = None
    except:
        pass

    push_log("[INFO] Programa terminado")

    if root is not None:
        try:
            root.after(200, root.destroy)
        except:
            pass


def create_gui():
    global root, status_label, log_text, entry_text, mode_label

    root = tk.Tk()
    root.title("Control ESP32")
    root.geometry("760x520")
    root.protocol("WM_DELETE_WINDOW", close_program)

    top_frame = tk.Frame(root)
    top_frame.pack(fill="x", padx=10, pady=10)

    status_label = tk.Label(top_frame, text=f"Conectado a {HOST}:{PORT}", font=("Arial", 11, "bold"))
    status_label.pack(anchor="w")

    mode_label = tk.Label(top_frame, text=f"Modo actual: {current_mode}", font=("Arial", 10))
    mode_label.pack(anchor="w", pady=(4, 0))

    controls_frame = tk.Frame(root)
    controls_frame.pack(fill="x", padx=10, pady=5)

    btn_manual = tk.Button(controls_frame, text="Modo MANUAL", width=15, command=set_mode_manual)
    btn_manual.grid(row=0, column=0, padx=5, pady=5)

    btn_auto = tk.Button(controls_frame, text="Modo AUTO", width=15, command=set_mode_auto)
    btn_auto.grid(row=0, column=1, padx=5, pady=5)

    btn_stop = tk.Button(controls_frame, text="STOP", width=15, command=send_stop)
    btn_stop.grid(row=0, column=2, padx=5, pady=5)

    btn_exit = tk.Button(controls_frame, text="Salir", width=15, command=close_program)
    btn_exit.grid(row=0, column=3, padx=5, pady=5)

    info_frame = tk.Frame(root)
    info_frame.pack(fill="x", padx=10, pady=5)

    info_label = tk.Label(
        info_frame,
        text="Controles: W=adelante | S=atras | A=izquierda | D=derecha | ESPACIO=STOP | M=MANUAL | O=AUTO | Q=salir",
        justify="left"
    )
    info_label.pack(anchor="w")

    send_frame = tk.Frame(root)
    send_frame.pack(fill="x", padx=10, pady=10)

    entry_text = tk.Entry(send_frame, font=("Arial", 11))
    entry_text.pack(side="left", fill="x", expand=True, padx=(0, 10))
    entry_text.bind("<Return>", lambda event: send_custom_text())

    btn_send = tk.Button(send_frame, text="Enviar texto", width=15, command=send_custom_text)
    btn_send.pack(side="right")

    log_text = scrolledtext.ScrolledText(root, wrap=tk.WORD, font=("Consolas", 10))
    log_text.pack(fill="both", expand=True, padx=10, pady=(0, 10))

    process_log_queue()


def main():
    global sock, running

    try:
        push_log(f"[INFO] Conectando a {HOST}:{PORT} ...")
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.connect((HOST, PORT))
        push_log("[INFO] Conectado")
    except Exception as e:
        print(f"[ERROR] No se pudo conectar: {e}")
        return

    recv_thread = threading.Thread(target=receiver_loop, daemon=True)
    send_thread = threading.Thread(target=sender_loop, daemon=True)

    recv_thread.start()
    send_thread.start()

    listener = keyboard.Listener(on_press=on_press, on_release=on_release)
    listener.daemon = True
    listener.start()

    create_gui()
    root.mainloop()

    running = False

    try:
        listener.stop()
    except:
        pass


if __name__ == "__main__":
    main()